# Copy this file to .env for local development (never commit .env)
DATABASE_URL=postgresql://localhost/phillies
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token-hex-32

# ── Google OAuth (sign-in) ────────────────────────────────────────────────
# Create an OAuth 2.0 Client ID in Google Cloud Console (Web application).
# Authorized redirect URI for prod: https://phillies.tashefamily.com/auth/callback
# For local dev also add: http://localhost:5000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google emails permitted to sign in.
# If unset, login is impossible (no implicit open access — set this for local dev).
ALLOWED_EMAILS=tom.folsom@gmail.com
